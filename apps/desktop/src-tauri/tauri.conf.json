{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexo",
  "version": "1.0.0",
  "identifier": "dev.nexo.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nexo",
        "width": 1180,
        "height": 760,
        "minWidth": 940,
        "minHeight": 620,
        "theme": "Dark",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "msi"],
    "publisher": "Nexo",
    "homepage": "https://github.com/harshvardhandpu/nexo",
    "category": "Utility",
    "shortDescription": "Encrypted, resumable peer-to-peer file transfer",
    "longDescription": "Nexo moves large files directly between devices over encrypted QUIC with chunk-level integrity and crash-safe resume — no cloud, no accounts. A premium, animated desktop experience similar to AirDrop and LocalSend.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "allowDowngrades": true,
      "wix": {
        "language": "en-US"
      }
    }
  }
}
