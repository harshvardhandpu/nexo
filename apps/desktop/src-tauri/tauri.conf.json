{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexo",
  "version": "0.1.0",
  "identifier": "dev.nexo.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nexo",
        "width": 1180,
        "height": 760,
        "minWidth": 940,
        "minHeight": 620,
        "theme": "Dark",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "category": "Utility",
    "shortDescription": "Encrypted, resumable QUIC file transfer",
    "longDescription": "Nexo moves large files over encrypted QUIC with chunk-level integrity and crash-safe resume, wrapped in a modern animated desktop interface.",
    "icon": ["icons/icon.png"],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  }
}
